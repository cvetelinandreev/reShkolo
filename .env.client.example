# Client-side env for Wasp (loaded only during `wasp start` / Vite dev).
# Copy to `.env.client` and adjust. Do not commit `.env.client` (see .gitignore).

# API base URL. In dev, Wasp defaults to http://localhost:3001 — fine when the browser
# runs on the same machine as the server.
#
# If you open the app from a phone or another device on your Wi‑Fi, localhost on that
# device is NOT your Mac. Set your Mac's LAN IP and restart `wasp start`:
#
#   REACT_APP_API_URL=http://192.168.1.10:3001
#
# Use the same host you type in the phone's browser for the app, with port **3001**
# (API server). Also set WASP_WEB_CLIENT_URL and WASP_SERVER_URL in `.env.server`
# (see `.env.server.example`) or the page can load but API calls fail.

REACT_APP_API_URL=http://localhost:3001
