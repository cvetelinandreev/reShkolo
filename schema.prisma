datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Space {
  id        String   @id @default(uuid())
  shortCode String   @unique
  name      String?
  createdAt DateTime @default(now())

  contributorHandles     ContributorHandle[]
  feedbackEntries        FeedbackEntry[]
  summary                SpaceSummary?
  spacePrompts        SpacePrompt[]
  spaceModels         SpaceModel[]
  summaryAggregations SpaceSummaryAggregation[]
}

model SpacePrompt {
  id                  String   @id @default(uuid())
  createdAt           DateTime @default(now())
  spaceId             String
  slug                String
  summaryPromptOutput String   @map("summary_prompt_output") @db.Text

  space        Space                     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  aggregations SpaceSummaryAggregation[]

  @@unique([spaceId, slug])
}

model SpaceModel {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  spaceId     String
  slug        String
  displayName String
  modelApiId  String

  space        Space                     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  aggregations SpaceSummaryAggregation[]

  @@unique([spaceId, slug])
}

model SpaceSummaryAggregation {
  id             String    @id @default(uuid())
  createdAt      DateTime  @default(now())
  spaceId        String
  promptId       String
  spaceModelId   String
  summaryText    String?   @db.Text
  summaryTextBg  String?   @db.Text
  // Per-language generation: pending | ready | failed
  langStatusEn   String    @default("pending")
  langStatusBg   String    @default("pending")
  jobError       String?   @db.Text
  jobStatus      String    @default("pending")
  updatedAt      DateTime?

  space      Space       @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  prompt     SpacePrompt @relation(fields: [promptId], references: [id], onDelete: Cascade)
  spaceModel SpaceModel  @relation(fields: [spaceModelId], references: [id], onDelete: Cascade)

  @@unique([promptId, spaceModelId])
}

model ContributorHandle {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  space   Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  spaceId String

  feedbackEntries FeedbackEntry[]
}

// sourceType: "text" | "voice"
// tone: "praise" | "constructive_criticism"
model FeedbackEntry {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  rawText    String
  tone       String
  sourceType String

  space   Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  spaceId String

  contributorHandle   ContributorHandle @relation(fields: [contributorHandleId], references: [id], onDelete: Cascade)
  contributorHandleId String
}

// jobStatus: "pending" | "ready" | "failed"
model SpaceSummary {
  spaceId String @id

  summaryText   String?
  summaryTextBg String?
  jobStatus   String @default("pending")

  totalCount    Int @default(0)
  positiveCount Int @default(0)
  negativeCount Int @default(0)

  updatedAt DateTime?

  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)
}

model AppSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}
