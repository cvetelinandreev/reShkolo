datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Space {
  id        String   @id @default(uuid())
  shortCode String   @unique
  name      String?
  createdAt DateTime @default(now())

  contributorHandles     ContributorHandle[]
  feedbackEntries        FeedbackEntry[]
  summary                SpaceSummary?
  experimentPrompts      SpaceExperimentPrompt[]
  experimentModels       SpaceExperimentModel[]
  summaryAggregations    SpaceSummaryAggregation[]
}

model SpaceExperimentPrompt {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  spaceId   String
  slug      String
  body      String   @db.Text

  space        Space                     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  aggregations SpaceSummaryAggregation[]

  @@unique([spaceId, slug])
}

model SpaceExperimentModel {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  spaceId     String
  slug        String
  displayName String
  modelApiId  String

  space        Space                     @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  aggregations SpaceSummaryAggregation[]

  @@unique([spaceId, slug])
}

model SpaceSummaryAggregation {
  id                  String    @id @default(uuid())
  createdAt           DateTime  @default(now())
  spaceId             String
  promptId            String
  experimentModelId String
  summaryText         String?   @db.Text
  summaryTextBg       String?   @db.Text
  jobError            String?   @db.Text
  jobStatus           String    @default("pending")
  updatedAt           DateTime?

  space    Space                 @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  prompt   SpaceExperimentPrompt @relation(fields: [promptId], references: [id], onDelete: Cascade)
  expModel SpaceExperimentModel  @relation(fields: [experimentModelId], references: [id], onDelete: Cascade)

  @@unique([promptId, experimentModelId])
}

model ContributorHandle {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  space   Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  spaceId String

  feedbackEntries FeedbackEntry[]
}

// sourceType: "text" | "voice"
// tone: "praise" | "constructive_criticism"
model FeedbackEntry {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  rawText    String
  tone       String
  sourceType String

  space   Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  spaceId String

  contributorHandle   ContributorHandle @relation(fields: [contributorHandleId], references: [id], onDelete: Cascade)
  contributorHandleId String
}

// jobStatus: "pending" | "ready" | "failed"
model SpaceSummary {
  spaceId String @id

  summaryText   String?
  summaryTextBg String?
  jobStatus   String @default("pending")

  totalCount    Int @default(0)
  positiveCount Int @default(0)
  negativeCount Int @default(0)

  updatedAt DateTime?

  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)
}

model AppSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}
