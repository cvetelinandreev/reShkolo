datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Space {
  id        String   @id @default(uuid())
  shortCode String   @unique
  name      String?
  createdAt DateTime @default(now())

  contributorHandles     ContributorHandle[]
  feedbackEntries        FeedbackEntry[]
  summaries              SpaceSummary[]
  spacePrompts        SpacePrompt[]
  spaceModels         SpaceModel[]
}

model SpacePrompt {
  id                  String   @id @default(uuid())
  createdAt           DateTime @default(now())
  spaceId             String
  slug                String
  summaryPromptOutput String   @map("summary_prompt_output") @db.Text

  space     Space           @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  summaries SpaceSummary[]

  @@unique([spaceId, slug])
}

model SpaceModel {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  spaceId     String
  slug        String
  displayName String
  modelApiId  String

  space     Space           @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  summaries SpaceSummary[]

  @@unique([spaceId, slug])
}

model SpaceSummary {
  id             String    @id @default(uuid())
  createdAt      DateTime  @default(now())
  spaceId        String
  promptId       String
  spaceModelId   String
  language       String
  summaryText    String?   @db.Text
  jobStatus      String    @default("pending")
  updatedAt      DateTime?

  space      Space       @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  prompt     SpacePrompt @relation(fields: [promptId], references: [id], onDelete: Cascade)
  spaceModel SpaceModel  @relation(fields: [spaceModelId], references: [id], onDelete: Cascade)

  @@unique([promptId, spaceModelId, language])
}

model ContributorHandle {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  space   Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  spaceId String

  feedbackEntries FeedbackEntry[]
}

// sourceType: "text" | "voice"
// tone: "praise" | "constructive_criticism"
model FeedbackEntry {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  rawText    String
  tone       String
  sourceType String

  space   Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  spaceId String

  contributorHandle   ContributorHandle @relation(fields: [contributorHandleId], references: [id], onDelete: Cascade)
  contributorHandleId String
}

model AppSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}
