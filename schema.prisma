datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Space {
  id        String   @id @default(uuid())
  shortCode String   @unique
  name      String?
  createdAt DateTime @default(now())

  contributorHandles ContributorHandle[] @relation("SpaceContributorMembership")
  feedbackEntries    FeedbackEntry[]
  summaries          SpaceSummary[]
  spacePrompts       SpacePrompt[]

  ownerContributorHandleId String?            @unique @map("owner_contributor_handle_id")
  ownerContributorHandle   ContributorHandle? @relation("SpaceOwnerContributor", fields: [ownerContributorHandleId], references: [id], onDelete: SetNull)
}

model SpacePrompt {
  id                  String   @id @default(uuid())
  createdAt           DateTime @default(now())
  spaceId             String
  slug                String
  summaryPromptOutput String   @map("summary_prompt_output") @db.Text

  space     Space           @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  summaries SpaceSummary[]

  @@unique([spaceId, slug])
}

model SpaceSummary {
  id             String    @id @default(uuid())
  createdAt      DateTime  @default(now())
  spaceId        String
  promptId       String
  modelSlug      String
  language       String
  summaryText    String?   @db.Text
  jobStatus      String    @default("pending")
  updatedAt      DateTime?

  space      Space       @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  prompt     SpacePrompt @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@unique([promptId, modelSlug, language])
}

model ContributorHandle {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  space   Space  @relation("SpaceContributorMembership", fields: [spaceId], references: [id], onDelete: Cascade)
  spaceId String

  ownerOfSpace Space? @relation("SpaceOwnerContributor")

  feedbackEntries FeedbackEntry[]
}

// sourceType: "text" | "voice"
// tone: "praise" | "constructive_criticism"
model FeedbackEntry {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  rawText    String
  tone       String
  sourceType String

  space   Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  spaceId String

  contributorHandle   ContributorHandle @relation(fields: [contributorHandleId], references: [id], onDelete: Cascade)
  contributorHandleId String
}

model AppSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}
