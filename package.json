{
  "name": "reshkolo",
  "type": "module",
  "engines": {
    "node": "22.22.2"
  },
  "packageManager": "npm@10.9.7",
  "scripts": {
    "wasp": "bash scripts/with-project-node.sh wasp",
    "wasp:log": "bash scripts/wasp-start-with-log.sh",
    "tail:wasp": "bash scripts/tail-wasp-log.sh",
    "db:migrate:dev": "bash scripts/with-project-node.sh wasp db migrate-dev",
    "db:migrate:deploy": "bash scripts/with-project-node.sh npx dotenv -e .env.server -- prisma migrate deploy --schema schema.prisma",
    "regenerate:summaries": "bash scripts/regenerate-all-summaries.sh",
    "db:studio": "bash scripts/with-project-node.sh npx dotenv -e .env.server -- prisma studio --schema=schema.prisma --port 5555",
    "start:phone": "bash ./scripts/start-phone-dev.sh"
  },
  "workspaces": [
    ".wasp/out/*",
    ".wasp/out/sdk/wasp"
  ],
  "dependencies": {
    "@headlessui/react": "^2.2.10",
    "@heroicons/react": "^2.2.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-hook-form": "^7.69.0",
    "react-router": "^7.12.0",
    "tailwind-merge": "~3.4.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^16.1.0",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "dotenv-cli": "^8.0.0",
    "prisma": "5.19.1",
    "typescript": "5.8.2",
    "typescript-eslint": "^8.32.1",
    "vite": "^7.0.6"
  }
}
