# Copy to .env.server for local Wasp development (never commit secrets).

# Optional: hosted LLM (Anthropic Messages API). If unset, classification uses a
# local heuristic and summaries are stats-only until you add a key.
ANTHROPIC_API_KEY=

# Optional model overrides (defaults are set in code).
ANTHROPIC_MODEL_CLASSIFY=claude-3-5-haiku-20241022
ANTHROPIC_MODEL_SUMMARY=claude-opus-4-20250514

# PostgreSQL connection string (required). For local Docker: `docker compose up -d`
# then use the URL below.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/resholo
