# Copy to .env.server for local Wasp development (never commit secrets).

# Phone / tablet on the same Wi‑Fi: use the **Network** URL from `wasp start` (Vite
# prints several IPs — try `192.168.x.x` first; `172.20.x.x` is often iPhone hotspot
# and may not route to your Mac). Use **http** and the client port (usually 3000) /
# server port (usually 3001). Unblocks CORS when not using localhost:
# WASP_WEB_CLIENT_URL=http://192.168.1.10:3000
# WASP_SERVER_URL=http://192.168.1.10:3001

# Optional: hosted LLM (Anthropic Messages API). If unset, classification uses a
# local heuristic and aggregation cards show a no-key message until you add a key.
ANTHROPIC_API_KEY=

# Optional model overrides (defaults are set in code). Classification uses only
# Anthropic when ANTHROPIC_API_KEY is set; other providers are for summaries only.
ANTHROPIC_MODEL_CLASSIFY=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_SUMMARY=claude-sonnet-4-6

# Optional: Google Gemini direct API (summaries / aggregation only).
GEMINI_API_KEY=
GEMINI_MODEL_SUMMARY=gemini-2.5-flash

# Optional: OpenAI direct API (summaries / aggregation only).
OPENAI_API_KEY=
OPENAI_MODEL_SUMMARY=gpt-5.5-mini

# Optional: Groq Cloud (OpenAI-compatible chat). High free-tier RPM vs Gemini.
# https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL_SUMMARY=meta-llama/llama-4-scout-17b-16e-instruct

# When true, server logs full LLM request payloads (system + user messages). Contains
# anonymous feedback text — use only in trusted dev environments, not production.
# LLM_DEBUG_LOG=true

# PostgreSQL connection string (required). For local Docker: `docker compose up -d`
# then use the URL below.
# Prisma Studio does not read this file by default — use `npm run db:studio` (loads
# `.env.server`) or duplicate DATABASE_URL into a root `.env` for plain `prisma studio`.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/reshkolo

# Optional: regenerate every space’s summaries (EN+BG) while dev server is up:
#   npm run regenerate:summaries
# (Uses POST /admin/regenerate-all-summaries with header x-reshkolo-regenerate-secret.)
REGENERATE_ALL_SUMMARIES_SECRET=

# After you edit AppSetting `default_summary_prompt_output` in the DB, push it to
# every space’s `default` prompt and regenerate summaries (no Wasp server needed):
#   npm run prompt:push-and-regenerate-all
